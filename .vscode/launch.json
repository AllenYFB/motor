{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F407",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/stm32F407IGT6.elf",
      "device": "STM32F407IG",
      "interface": "swd",
      "preLaunchTask": "Build Debug",
      "gdbPath": "C:/Program Files (x86)/Arm GNU Toolchain arm-none-eabi/12.2 mpacbti-rel1/bin/arm-none-eabi-gdb.exe",
      "serverpath": "D:/OpenOCD-20240916-0.12.0/bin/openocd.exe",
      "searchDir": [
        "D:/OpenOCD-20240916-0.12.0/share/openocd/scripts"
      ],
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f4x.cfg"
      ],
      "openOCDLaunchCommands": [
        "transport select swd",
        "adapter speed 4000"
      ],
      "showDevDebugOutput": "raw"
    }
  ]
}
